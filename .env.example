# Database (auto-injected by BuildWithLocus Postgres addon)
DATABASE_URL="file:./dev.db"

# Locus Platform API Key (for BuildWithLocus)
LOCUS_API_KEY="claw_..."

# PayWithLocus Beta API
LOCUS_PAY_API_URL="https://beta-api.paywithlocus.com/api"
LOCUS_PAY_API_KEY="your-locus-pay-api-key"

# Encryption key for storing Locus API keys at rest (32-byte hex)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# JWT Secret for auth
JWT_SECRET="your-jwt-secret-change-in-production"

# AI (Gemini)
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=8080
